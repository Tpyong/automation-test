[run]
source =
    core/
    config/

omit =
    */__pycache__/*
    */tests/*
    */test_*.py
    */*_test.py
    */venv/*
    */.venv/*

[report]
show_missing = true
skip_covered = false
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = reports/coverage-html
title = 测试覆盖率报告
