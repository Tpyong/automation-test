# 基础配置文件
# 所有环境的默认配置

# 基础 URL 配置
BASE_URL=https://www.example.com
API_BASE_URL=https://api.example.com

# 浏览器配置
BROWSER=chromium
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# 视口配置
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
API_TIMEOUT=30000

# 录屏配置
VIDEO_ENABLED=true

# 数据库配置（默认值）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=test_db